# Copy to secrets.yaml in the same folder as parking_bay_esp32cam.yaml
# Generate api_encryption_key in ESPHome dashboard when adding the device.

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

api_encryption_key: "base64keyFromEsphomeDashboard=="
ota_password: "choose-a-strong-ota-password"
ap_password: "fallback-ap-password"
