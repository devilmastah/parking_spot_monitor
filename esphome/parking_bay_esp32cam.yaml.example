# ESPHome example: one ESP32-CAM per parking bay
# Copy and adjust for each bay (unique esphome.name / friendly_name).
# After flashing, add the camera entity to Parking Spot Monitor.

esphome:
  name: parking-bay-1
  friendly_name: Parking Bay 1

esp32:
  board: esp32dev
  framework:
    type: arduino

logger:

api:
  encryption:
    key: !secret api_encryption_key

ota:
  - platform: esphome
    password: !secret ota_password

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  ap:
    ssid: "Parking-Bay-1 Fallback"
    password: !secret ap_password

captive_portal:

# AI-Thinker ESP32-CAM pinout
esp32_camera:
  name: Parking Bay 1
  external_clock:
    pin: GPIO0
    frequency: 20MHz
  i2c_pins:
    sda: GPIO26
    scl: GPIO27
  data_pins: [GPIO5, GPIO18, GPIO19, GPIO21, GPIO36, GPIO39, GPIO34, GPIO35]
  vsync_pin: GPIO25
  href_pin: GPIO23
  pixel_clock_pin: GPIO22
  power_down_pin: GPIO32
  resolution: 800x600
  jpeg_quality: 10
  max_framerate: 1 fps
  idle_framerate: 0.2 fps

# Optional flash LED (GPIO4 on most ESP32-CAM boards)
output:
  - platform: gpio
    pin: GPIO4
    id: status_led

# Keep WiFi load low: HA fetches a snapshot on demand via camera_proxy.
# Parking Spot Monitor triggers bays one at a time with a delay between them.
